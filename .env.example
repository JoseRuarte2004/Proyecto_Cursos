# Frontend (Vercel)
VITE_API_BASE_URL=https://api.example.com/api

# Shared public URLs
APP_ENV=production
FRONTEND_BASE_URL=https://app.example.com
FRONT_ORIGIN=https://app.example.com
PUBLIC_BASE_URL=https://api.example.com
APP_BASE_URL=https://api.example.com

# Security / auth
JWT_SECRET=replace-with-a-strong-random-secret
USERS_API_JWT_SECRET=replace-with-a-strong-random-secret
USERS_INTERNAL_TOKEN=replace-with-an-internal-token
COURSES_INTERNAL_TOKEN=replace-with-an-internal-token
CONTENT_INTERNAL_TOKEN=replace-with-an-internal-token
ENROLL_INTERNAL_TOKEN=replace-with-an-internal-token
ENROLLMENTS_INTERNAL_TOKEN=replace-with-an-internal-token
PAYMENTS_INTERNAL_TOKEN=replace-with-an-internal-token
CHAT_INTERNAL_TOKEN=replace-with-an-internal-token

# Public gateway / security.txt
SECURITY_TXT_CONTACT=mailto:security@example.com
SECURITY_TXT_EXPIRES=2027-12-31T23:59:59Z
SECURITY_TXT_LANGUAGES=es, en
SECURITY_TXT_CANONICAL=https://api.example.com/.well-known/security.txt

# Managed Postgres (Render)
DB_HOST=platform-postgres
DB_PORT=5432
DB_USER=platform
DB_PASSWORD=replace-with-db-password
DB_NAME=platform_prod
POSTGRES_DB=platform_prod
POSTGRES_USER=platform
POSTGRES_PASSWORD=replace-with-db-password

# Shared connection strings
USERS_API_DATABASE_URL=postgres://platform:replace-with-db-password@platform-postgres:5432/platform_prod?sslmode=disable
COURSES_DB_DSN=postgres://platform:replace-with-db-password@platform-postgres:5432/platform_prod?sslmode=disable
CONTENT_DB_DSN=postgres://platform:replace-with-db-password@platform-postgres:5432/platform_prod?sslmode=disable
ENROLLMENTS_DB_DSN=postgres://platform:replace-with-db-password@platform-postgres:5432/platform_prod?sslmode=disable
PAYMENTS_DB_DSN=postgres://platform:replace-with-db-password@platform-postgres:5432/platform_prod?sslmode=disable
CHAT_DB_DSN=postgres://platform:replace-with-db-password@platform-postgres:5432/platform_prod?sslmode=disable

# Redis / RabbitMQ (Render private network)
REDIS_URL=redis://platform-redis:6379/0
USERS_API_REDIS_URL=redis://platform-redis:6379/0
COURSES_REDIS_ADDR=redis://platform-redis:6379/1
REDIS_ADDR=redis://platform-redis:6379/2
RABBITMQ_URL=amqp://replace-with-rabbitmq-user:replace-with-rabbitmq-password@platform-rabbitmq:5672/
RABBITMQ_DEFAULT_USER=replace-with-rabbitmq-user
RABBITMQ_DEFAULT_PASS=replace-with-rabbitmq-password

# Internal service URLs (Render private services)
USERS_API_BASE_URL=http://users-api:8081
COURSES_API_BASE_URL=http://courses-api:8082
ENROLLMENTS_API_BASE_URL=http://enrollments-api:8084
USERS_API_UPSTREAM=http://users-api:8081
COURSES_API_UPSTREAM=http://courses-api:8082
CONTENT_API_UPSTREAM=http://course-content-api:8083
ENROLLMENTS_API_UPSTREAM=http://enrollments-api:8084
PAYMENTS_API_UPSTREAM=http://payments-api:8085
CHAT_API_UPSTREAM=http://chat-api:8090

# users-api
USERS_API_ADDR=:8081
USERS_API_JWT_TTL=24h
EMAIL_PROVIDER=smtp
EMAIL_FROM=no-reply@example.com
SMTP_HOST=replace-with-smtp-host
SMTP_PORT=587
SMTP_USER=replace-with-smtp-user
SMTP_PASS=replace-with-smtp-password
SMTP_FROM=no-reply@example.com
RESEND_API_KEY=
SENDGRID_API_KEY=
TOKEN_EMAIL_VERIFY_TTL_HOURS=24
TOKEN_PASSWORD_RESET_TTL_MINUTES=60
REQUIRE_EMAIL_VERIFICATION_FOR_LOGIN=false
USERS_API_BOOTSTRAP_ADMIN_NAME=Platform Admin
USERS_API_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
USERS_API_BOOTSTRAP_ADMIN_PASSWORD=replace-with-admin-password

# courses-api
COURSES_API_ADDR=:8082
COURSES_CACHE_TTL=5m
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

# course-content-api
COURSE_CONTENT_API_ADDR=:8083

# enrollments-api
ENROLLMENTS_API_ADDR=:8084
ENROLLMENTS_SERVICE_NAME=enrollments-api

# payments-api
PAYMENTS_API_ADDR=:8085
PAYMENTS_SERVICE_NAME=payments-api
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_CHECKOUT_ENV=production
WEBHOOK_SECRET_STRIPE=

# chat-api
CHAT_API_ADDR=:8090
CHAT_SERVICE_NAME=chat-api
CHAT_FANOUT_MODE=memory
CHAT_ALLOWED_ORIGINS=https://app.example.com

# Local-only ports (Docker Compose development)
POSTGRES_PORT=5432
REDIS_PORT=6379
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
NGINX_PORT=8080
USERS_API_PORT=8081
COURSES_API_PORT=8082
COURSE_CONTENT_API_PORT=8083
ENROLLMENTS_API_PORT=8084
PAYMENTS_API_PORT=8085
CHAT_API_PORT=8090
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
