WEBHOOK_SECRET_STRIPE=

# chat-api
CHAT_API_PORT=8090
CHAT_API_ADDR=:8090
CHAT_DB_DSN=postgres://postgres:postgres@postgres:5432/platform_dev?sslmode=disable
SERVICE_NAME=chat-api
# reuses shared COURSES_API_BASE_URL and ENROLLMENTS_API_BASE_URL above
CHAT_FANOUT_MODE=memory
CHAT_ALLOWED_ORIGINS=
REDIS_ADDR=redis://redis:6379/2

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
