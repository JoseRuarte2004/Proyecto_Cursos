# Shared infrastructure
POSTGRES_DB=platform_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

NGINX_PORT=8080
FRONT_ORIGIN=http://localhost:5173
APP_BASE_URL=http://localhost:8080
PUBLIC_BASE_URL=http://localhost:8080
FRONTEND_BASE_URL=http://localhost:8080
APP_ENV=dev
SECURITY_TXT_CONTACT=mailto:security@replace-me.invalid
SECURITY_TXT_EXPIRES=2027-12-31T23:59:59Z
SECURITY_TXT_LANGUAGES=es, en
SECURITY_TXT_CANONICAL=http://localhost:8080/.well-known/security.txt

# users-api
USERS_API_PORT=8081
USERS_API_ADDR=:8081
USERS_API_DATABASE_URL=postgres://postgres:postgres@postgres:5432/platform_dev?sslmode=disable
USERS_API_REDIS_URL=redis://redis:6379/0
USERS_API_JWT_SECRET=change-me
USERS_API_JWT_TTL=24h
EMAIL_PROVIDER=smtp
EMAIL_FROM=no-reply@example.com
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
RESEND_API_KEY=
SENDGRID_API_KEY=
TOKEN_EMAIL_VERIFY_TTL_HOURS=24
TOKEN_PASSWORD_RESET_TTL_MINUTES=60
REQUIRE_EMAIL_VERIFICATION_FOR_LOGIN=false
USERS_API_BOOTSTRAP_ADMIN_NAME=Platform Admin
USERS_API_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
USERS_API_BOOTSTRAP_ADMIN_PASSWORD=admin1234

# shared auth
JWT_SECRET=change-me
USERS_INTERNAL_TOKEN=internal-users
COURSES_INTERNAL_TOKEN=internal-courses
CONTENT_INTERNAL_TOKEN=internal-content
ENROLL_INTERNAL_TOKEN=internal-enrollments
PAYMENTS_INTERNAL_TOKEN=internal-payments
CHAT_INTERNAL_TOKEN=internal-chat

# courses-api
COURSES_DB_DSN=postgres://postgres:postgres@postgres:5432/platform_dev?sslmode=disable
COURSES_REDIS_ADDR=redis://redis:6379/1
USERS_API_BASE_URL=http://users-api:8081
COURSES_CACHE_TTL=5m

# courses-api
COURSES_API_PORT=8082
COURSES_API_ADDR=:8082

# course-content-api
COURSE_CONTENT_API_PORT=8083
COURSE_CONTENT_API_ADDR=:8083
CONTENT_DB_DSN=postgres://postgres:postgres@postgres:5432/platform_dev?sslmode=disable
COURSES_API_BASE_URL=http://courses-api:8082
ENROLLMENTS_API_BASE_URL=http://enrollments-api:8084

# enrollments-api
ENROLLMENTS_API_PORT=8084
ENROLLMENTS_API_ADDR=:8084
ENROLLMENTS_DB_DSN=postgres://postgres:postgres@postgres:5432/platform_dev?sslmode=disable
ENROLLMENTS_SERVICE_NAME=enrollments-api
ENROLLMENTS_INTERNAL_TOKEN=internal-enrollments

# payments-api
PAYMENTS_API_PORT=8085
PAYMENTS_API_ADDR=:8085
PAYMENTS_DB_DSN=postgres://postgres:postgres@postgres:5432/platform_dev?sslmode=disable
PAYMENTS_SERVICE_NAME=payments-api
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
